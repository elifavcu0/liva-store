@using Microsoft.AspNetCore.SignalR.Protocol
@using liva_store.Data
@model List<WishlistItem>

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0 ">
                    <li class="breadcrumb-item ">
                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a>
                    </li>
                    <li class="breadcrumb-item active">
                        <a asp-controller="Wishlist" asp-action="Index" class="text-decoration-none">Wish List
                        </a>
                    </li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-3">
    <div class="container" id="wishlist-container">
        @if (Model.Count == 0)
        {
               <div class="col-12 text-center py-5 mt-4 fade-in">
                        <i class="fa-regular fa-heart fa-4x mb-3" style="color: #dee2e6;"></i>
                        <h4 class="text-muted">Your wish list is currently empty.</h4>
                        <p class="text-muted mb-4">You can add your favorite products to your favorites list to easily find them later.</p>
                        <a asp-controller="Home" asp-action="Index" class="btn text-white" style="background-color: #881337;">Start Shopping</a>
                    </div>
        }
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
            @foreach (var item in Model)
            {
                <div class="col" id="wishlist-card-@item.ProductId">
                    <div class="card shadow mb-3 position-relative h-100">
                        <button class="btn btn-light btn-sm text-liva position-absolute top-0 end-0 m-2 z-3 shadow-sm"
                                onclick="removeFromWishlistPage(@item.ProductId)">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                        <div class="img-wrap">
                            @if (!item.Product.IsActive)
                            {
                                <span class="badge bg-danger">Sold Out</span>
                            }
                            else if (item.Product.IsOnSale)
                            {
                                <span class="badge bg-success">-%@item.Product.DiscountRate</span>
                            }

                            <img src="~/img/@item.Product.Image" alt="@item.Product.Name" class="card-img-top">
                            </div>
                            <div class="border-top info-wrap">

                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Product.Id"
                                   class="title text-truncate">@item.Product.Name</a>
                                <div class="mb-3 price-wrap">
                                    <span class="price-discount fw-bold">@((item.Product.DiscountedPrice()).ToString("C2"))</span>
                                    @if (item.Product.DiscountRate != 0)
                                    {
                                        <del class="price"><small>@item.Product.Price.ToString("C2")</small></del>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>