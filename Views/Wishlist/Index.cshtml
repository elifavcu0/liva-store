@using liva_store.Data
@model List<WishlistItem>

@section Bar {
    <section class="bg-primary p-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0 ">
                    <li class="breadcrumb-item ">
                        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a>
                    </li>
                    <li class="breadcrumb-item active">
                        <a asp-controller="Wishlist" asp-action="Index" class="text-decoration-none">Wish List
                        </a>
                    </li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="mt-3">
        <div class="container"> 
            @if(Model.Count()!= 0){
            <div class="row">
                <div class="col-lg-7">
                        <ul class="list-group">
                            @foreach(var item in Model){
                            <li class="py-3 mb-2 border-top list-group-item">
                                <div class="row align-items-center">
                                    <div class="col-7">
                                        <div class="d-flex align-items-center">
                                            <img src="~/img/@item.Product.Image" style="width: 100px;" alt="">
                                            <div class="ms-3">
                                                <a class="text-decoration-none" asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">
                                                    <h6 class="mb-0">@item.Product.Name</h6>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-2 text-center">
                                        <span class=" fw-bold">@((item.Product.Price).ToString("C2"))</span> 
                                    </div>
                                    @* Silme işlevi eklenecek *@
                                    <div class="col-1">
                                        <button type="submit" class="btn btn-outline-primary btn-sm me-2" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-title="Delete" ><i class="fa-solid fa-trash-can"></i></button></div>
                                </div>
                            </li>}
                        </ul>
                </div></div>}else{<div class=" alert alert-warning">There's no item.</div>}
